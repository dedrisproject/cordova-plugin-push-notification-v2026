<?xml version='1.0' encoding='utf-8'?>
<widget id="com.dedrisproject.pushdemo" version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>PushDemo</name>
    <description>Sample app for cordova-plugin-push-notification-v2026</description>
    <author email="dedrisproject@gmail.com" href="https://github.com/dedrisproject">
        dedrisproject
    </author>

    <content src="index.html" />

    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <preference name="DisallowOverscroll" value="true" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="StatusBarOverlaysWebView" value="false" />

    <!-- Android -->
    <platform name="android">
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="35" />
        <allow-intent href="market:*" />
    </platform>

    <!-- iOS -->
    <platform name="ios">
        <preference name="deployment-target" value="13.0" />
        <preference name="WKWebViewOnly" value="true" />
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
    </platform>

    <!-- The plugin is added by setup.sh (local) or:
         cordova plugin add cordova-plugin-push-notification-v2026 -->

</widget>
